{
  "name": "electron-kiosk",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.kiosk.app",
    "productName": "Kiosk",
    "win": {
      "target": "portable",
      "icon": null
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "fisier.txt",
        "to": "fisier.txt"
      }
    ]
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  }
}
